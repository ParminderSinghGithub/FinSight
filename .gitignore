# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# =============================================================================
# Virtual environment
# =============================================================================
venv/
.venv/
env/
.env/

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.*
*.env
secrets.yaml
secrets.json

# =============================================================================
# FAISS indexes (binary, large, fully regeneratable via build_and_test_indexes.py)
# =============================================================================
indexes/faiss_text.index
indexes/faiss_code.index
indexes/faiss_image.index

# Whoosh BM25 indexes (regeneratable via HybridSearchEngine.from_disk(rebuild_bm25=True))
indexes/whoosh_text/
indexes/whoosh_code/

# Keep the indexes/ directory itself tracked
!indexes/.gitkeep

# =============================================================================
# Generated processed data  (all regeneratable from raw sources)
# =============================================================================
data/processed/chunked_text.json
data/processed/chunked_code.json
data/processed/image_metadata.json
data/processed/metadata.json

# evaluation_queries.json is hand-labeled ground truth — DO NOT ignore
# data/processed/evaluation_queries.json

# =============================================================================
# Generated raw images  (regeneratable via data_generation/generate_ml_visualizations.py)
# =============================================================================
data/raw/images/*.png
data/raw/images/*.jpg
data/raw/images/*.jpeg

# =============================================================================
# FAISS id-map JSON sidecars  (regeneratable alongside .index files)
# =============================================================================
indexes/faiss_*_idmap.json

# =============================================================================
# HuggingFace / model caches  (large, downloaded on demand)
# =============================================================================
.cache/
*.cache/
huggingface/
models/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Build / distribution / packaging
# =============================================================================
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# =============================================================================
# Type checking / linting
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.pytest_cache

# =============================================================================
# OS / editor artifacts
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes

# VS Code (keep workspace settings but not local machine state)
.vscode/launch.json
.vscode/.ropeproject

# PyCharm
.idea/

# =============================================================================
# Logs and temp files
# =============================================================================
*.log
*.tmp
*.temp
_nonascii.txt
