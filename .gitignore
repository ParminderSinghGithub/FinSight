# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# =============================================================================
# Virtual environment
# =============================================================================
venv/
.venv/
env/
.env/

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.*
*.env
secrets.yaml
secrets.json

# =============================================================================
# FAISS indexes (binary, large, fully regeneratable via build_and_test_indexes.py)
# =============================================================================
indexes/faiss_text.index
indexes/faiss_code.index
indexes/faiss_image.index
indexes_main/faiss_text.index
indexes_main/faiss_code.index
indexes_main/faiss_image.index

# Whoosh BM25 indexes (regeneratable via HybridSearchEngine.from_disk(rebuild_bm25=True))
indexes/whoosh_text/
indexes/whoosh_code/
indexes_main/whoosh_text/
indexes_main/whoosh_code/

# Keep the indexes/ directory itself tracked
!indexes/.gitkeep
!indexes_main/.gitkeep

# =============================================================================
# Dataset contents (ignore all data files; track only directory structure)
# =============================================================================
data/**
data_sample/**
data_main/**
data_main/raw_/**

!data/**/
!data/**/.gitkeep

!data_sample/**/
!data_sample/**/.gitkeep

!data_main/**/
!data_main/**/.gitkeep

# Keep the backup snapshot out of git entirely.
data_main/raw_/

# =============================================================================
# FAISS id-map JSON sidecars  (regeneratable alongside .index files)
# =============================================================================
indexes/faiss_*_idmap.json
indexes_main/faiss_*_idmap.json

# =============================================================================
# HuggingFace / model caches  (large, downloaded on demand)
# =============================================================================
.cache/
*.cache/
huggingface/
models/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Build / distribution / packaging
# =============================================================================
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# =============================================================================
# Type checking / linting
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.pytest_cache

# =============================================================================
# OS / editor artifacts
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes

# VS Code (keep workspace settings but not local machine state)
.vscode/launch.json
.vscode/.ropeproject

# PyCharm
.idea/

# =============================================================================
# Logs and temp files
# =============================================================================
*.log
*.tmp
*.temp
_nonascii.txt


p2_kaggle_package.zip
fintech_data.zip
x.md
